# Bible AI Assistant - Environment Variables
# Copy this file to .env and fill in values. Never commit .env.

# ---------------------------------------------------------------------------
# Hugging Face (model download, upload fine-tuned model)
# https://huggingface.co/settings/tokens
# ---------------------------------------------------------------------------
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ---------------------------------------------------------------------------
# Weights & Biases (training experiment tracking)
# https://wandb.ai/authorize
# ---------------------------------------------------------------------------
WANDB_API_KEY=your_wandb_api_key_here

# ---------------------------------------------------------------------------
# RAG / LLM endpoints (defaults used if not set)
# ---------------------------------------------------------------------------
# RAG_HOST=127.0.0.1          (rag_server listen host)
# RAG_PORT=8081               (rag_server listen port)
# RAG_SERVER_URL=http://127.0.0.1:8081   (used by ui/app.py to reach the RAG server)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=bible-assistant-orpo
# TTS_URL=http://127.0.0.1:8880

# ---------------------------------------------------------------------------
# RAG tuning parameters
# ---------------------------------------------------------------------------
# RAG_TOP_K=5
# HYBRID_CANDIDATES=20

# ---------------------------------------------------------------------------
# Gradio UI
# ---------------------------------------------------------------------------
# GRADIO_HOST=127.0.0.1
# GRADIO_PORT=7860

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# API_KEY=                    (empty = auth disabled for local dev)
#                             (set a strong random key for any networked deploy)

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# LOG_LEVEL=INFO              (DEBUG | INFO | WARNING | ERROR | CRITICAL)
# LOG_JSON=false              (set true in production for structured JSON logs)

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
# RATE_LIMIT=60/minute        (requests per window per IP)
