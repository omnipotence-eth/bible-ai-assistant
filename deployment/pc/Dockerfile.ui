# ── Stage 1: builder ──────────────────────────────────────────────────────────
FROM python:3.11.12-slim AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Copy metadata first — deps layer is cached until pyproject.toml changes.
COPY pyproject.toml README.md ./
RUN mkdir -p rag training ui voice scripts && touch ui/__init__.py

# Install dependencies into /install (cached until pyproject.toml changes).
RUN pip install --no-cache-dir --prefix=/install ".[ui]"

# Copy real source — no package entry point needed (CMD runs ui/app.py directly).
COPY ui/ ./ui/


# ── Stage 2: runtime ──────────────────────────────────────────────────────────
FROM python:3.11.12-slim AS runtime

# ffmpeg is a runtime dependency for audio processing.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 1001 appgroup && \
    useradd --uid 1001 --gid appgroup --create-home appuser

WORKDIR /app

COPY --from=builder /install /usr/local
COPY --from=builder /build/ui/ ./ui/

# HF model cache lives inside /app so appuser can write to it.
ENV HF_HOME=/app/.cache/huggingface
RUN mkdir -p /app/.cache/huggingface && chown -R appuser:appgroup /app
USER appuser

EXPOSE 7860

CMD ["python", "ui/app.py"]
